{
  "name": "linkor",
  "version": "1.0.15",
  "description": "Linkor desktop app",
  "main": "main.js",
  "author": "Linkor org.",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win nsis",
    "publish": "electron-builder --win nsis --publish always"
  },
  "devDependencies": {
    "electron": "latest",
    "electron-builder": "latest"
  },
  "build": {
    "appId": "com.linkor.app",
    "productName": "Linkor",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "neurospace.html",
      "script.js",
      "style.css",
      "changelog.json",
      "supabaseClient.js",
      "assets/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": {
      "provider": "github",
      "owner": "Tekarugod",
      "repo": "linkor-app",
      "releaseType": "release"
    }
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.1",
    "electron-updater": "^6.8.3"
  }
}
